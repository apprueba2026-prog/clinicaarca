# Supabase - Cliente (expuestas al navegador)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Supabase - Servidor (NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Resend — Servicio de email
RESEND_API_KEY=re_tu_api_key_aqui
RESEND_FROM_EMAIL=Clínica Arca <noreply@tudominio.com>

# Cron — Secret para proteger endpoints cron
CRON_SECRET=tu_cron_secret_aqui

# Google Gemini AI (Fase 8 - Arca Assistant)
# Obtener en: https://aistudio.google.com/apikey
# Activar billing para superar el cap de 20 req/día del free tier
GOOGLE_GENERATIVE_AI_API_KEY=tu_api_key_aqui

# Rate limiting del Arca Assistant:
#  - Capa 1 (edge): Vercel WAF — configurar en Dashboard → Project → Firewall
#    Regla sugerida: path /api/ai/chat → 30 req / 15min por IP
#  - Capa 2 (server): RPC check_rate_limit() en Supabase (ver supabase/14_rate_limits.sql)
#    No requiere variables de entorno adicionales (usa SUPABASE_SERVICE_ROLE_KEY)

# Telegram — Noé bot (recordatorios pacientes + reporte diario doctores)
# 1. Crear bot con @BotFather en Telegram → /newbot → obtener token
# 2. Configurar /setprivacy = Disable si quieres ver todos los mensajes
# 3. Tras desplegar, ejecutar: node scripts/register-telegram-webhook.mjs
TELEGRAM_BOT_TOKEN=7XXXXXXXXX:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=genera_64_chars_random_aqui
TELEGRAM_BOT_USERNAME=NoeClinicaArcaBot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=NoeClinicaArcaBot
# URL pública del webhook (usada por scripts/register-telegram-webhook.mjs)
TELEGRAM_WEBHOOK_URL=https://tudominio.com/api/telegram/webhook
